# Google Gemini API
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Temperature (0.0 = deterministic, 1.0 = creative)
# Recommended: 0.2 for balanced consistency + quality
# Lower values (0.1-0.3) provide more consistent safety verdicts
# Higher values (0.5-0.8) allow more variation in explanations
GEMINI_TEMPERATURE=0.2

# Meta WhatsApp Business API
# Get from: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# Telegram Bot API
# Create a bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: App URL for Webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000
